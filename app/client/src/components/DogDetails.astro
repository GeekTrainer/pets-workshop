---
interface Dog {
  id: number;
  name: string;
  breed: string;
  age: number;
  description: string;
  gender: string;
  status: 'AVAILABLE' | 'PENDING' | 'ADOPTED';
}

interface Props {
  dog: Dog;
}

const { dog } = Astro.props;
---

<div class="bg-slate-800/70 backdrop-blur-sm border border-slate-700 rounded-xl overflow-hidden" data-testid="dog-details">
  <div class="p-6">
    <div class="flex justify-between items-start">
      <h1 class="text-3xl font-bold text-slate-100 mb-2" data-testid="dog-name">{dog.name}</h1>
      {dog.status === 'AVAILABLE' ? (
        <span class="bg-green-500/20 text-green-400 text-sm px-3 py-1 rounded-full" data-testid="dog-status">Available</span>
      ) : dog.status === 'PENDING' ? (
        <span class="bg-amber-500/20 text-amber-400 text-sm px-3 py-1 rounded-full" data-testid="dog-status">Pending Adoption</span>
      ) : (
        <span class="bg-red-500/20 text-red-400 text-sm px-3 py-1 rounded-full" data-testid="dog-status">Adopted</span>
      )}
    </div>

    <div class="grid grid-cols-2 gap-4 mb-6 mt-4">
      <div class="flex items-center">
        <p class="text-slate-300" data-testid="dog-breed">Breed: {dog.breed}</p>
      </div>
      <div class="flex items-center">
        <p class="text-slate-300" data-testid="dog-age">Age: {dog.age} {dog.age === 1 ? 'year' : 'years'}</p>
      </div>
      <div class="flex items-center">
        <p class="text-slate-300" data-testid="dog-gender">Gender: {dog.gender}</p>
      </div>
    </div>

    <h2 class="text-lg font-semibold text-slate-200 mb-2">About {dog.name}</h2>
    <p class="text-slate-400" data-testid="dog-description">{dog.description}</p>
  </div>
</div>

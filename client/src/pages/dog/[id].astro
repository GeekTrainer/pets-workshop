---
import Layout from '../../layouts/Layout.astro';
import DogDetails from '../../components/DogDetails.astro';

const API_SERVER_URL = process.env.API_SERVER_URL || 'http://localhost:5100';

const { id } = Astro.params;
const dogId = parseInt(id || '0');

let dog = null;
let error: string | null = null;

try {
  const response = await fetch(`${API_SERVER_URL}/api/dogs/${dogId}`);
  if (response.ok) {
    dog = await response.json();
  } else if (response.status === 404) {
    error = 'Dog not found';
  } else {
    error = `Failed to fetch dog: ${response.status} ${response.statusText}`;
  }
} catch (err) {
  error = `Error: ${err instanceof Error ? err.message : String(err)}`;
}
---

<Layout title="Dog Details - Tailspin Shelter">
  <div class="py-8">
    {error ? (
      <div class="bg-red-500/20 border border-red-500/50 text-red-400 rounded-xl p-6" data-testid="error-message">
        {error}
      </div>
    ) : dog ? (
      <DogDetails dog={dog} />
    ) : (
      <div class="bg-slate-800/60 backdrop-blur-sm rounded-xl p-6">
        <p class="text-slate-400">No dog information available</p>
      </div>
    )}

    <div class="mt-8">
      <a href="/" data-testid="back-link" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-all duration-300 inline-flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
        </svg>
        Back to All Dogs
      </a>
    </div>
  </div>
</Layout>